Bootstrap: docker
From: python:3.10

%post
    pip install biser
    pip3 install numpy==1.26.4
    apt-get update
    apt-get install --assume-yes liblzma-dev tabix bedtools
    wget https://github.com/samtools/samtools/releases/download/1.22/samtools-1.22.tar.bz2
    tar -vxjf samtools-1.22.tar.bz2
    cd samtools-1.22
    make
    make prefix=/usr/local/bin install
    ln -s /usr/local/bin/bin/samtools /usr/bin/samtools

%environment
    export LC_ALL=C
