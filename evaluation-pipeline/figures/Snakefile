rule all:
	input:
		"unpolished_qvs_hist.pdf",
		"polished_qvs_hist.pdf",
		"polishing_variantsets_vQVs.pdf",
		"polishing_variantsets_kQVs.pdf",
		"kmer-QV_boxplots.pdf",
		"variant-QV_boxplots.pdf",
		"variant_overlap_improvements.pdf"

"""
Plots multiple variant-based QV value histograms into one plot
"""

rule plot_hist_unpolished:
	input:
		unpolished_tsvs
	output:
		"unpolished_qvs_hist.pdf"
	conda:
		"matplotlib.yml"
	shell:
		"""
		ls {input} | python3 plot-score-hist.py {output} "unpolished consensus haplotypes"
		"""



rule plot_hist_polished:
	input:
		polished_tsvs
	output:
		"polished_qvs_hist.pdf"
	conda:
		"matplotlib.yml"
	shell:
		"""
		ls {input} | python3 plot-score-hist.py {output} "polished consensus haplotypes"
		"""



rule plot_by_variants:
	"""
	Bar plots showing variant/kmer based QVs for polishing with only SNPs, SNPs+indels and all variants.
	"""
	input:
		vqv = variants_vQVs,
		kqv = variants_kQVs 
	output:
		vqv = "polishing_variantsets_vQVs.pdf",
		kqv = "polishing_variantsets_kQVs.pdf"
	conda:
		"matplotlib.yml"
	shell:
		"""
		ls {input.vqv} | python3 plot-by-variantset.py {output.vqv} variant
		ls {input.kqv} | python3 plot-by-variantset.py {output.kqv} kmer
		"""




rule plot_variant_number_changes:
	"""
	Plots the differences of variant overlaps with ground truth assemblies (PAV upset plots)
	between polished and unpolished haplotypes.
	"""
	input:
		variant_overlaps
	output:
		"variant_overlap_improvements.pdf"
	conda:
		"matplotlib.yml"
	log:
		"variant_overlap_improvements.log"
	shell:
		"""
		ls {input} | python3 plot_calling_improvements.py {output} &> {log}
		"""


rule plot_kmer_qv_boxplot:
	"""
	Plot boxplots of unpolished and polished kmer-based QVs, as well as assemblies.
	"""
	input:
		qvs = kmer_qvs,
		assembly_qvs = "/gpfs/project/projects/medbioinf/users/ebler/hgsvc3/data/hgsvc3_varcall_qvest.tsv" 
	output:
		"kmer-QV_boxplots.pdf"
	conda:
		"matplotlib.yml"
	log:
		"kmer-QV_boxplots.log"
	shell:
		"""
		ls {input.qvs} | python3 plot-qv-merqury.py {output} -assembly {input.assembly_qvs} &> {log}
		"""


rule plot_variant_qv_boxplot:
	"""
	Plot boxplots of unpolished and polished variant-based QVs.
	"""
	input:
		qvs = variant_qvs
	output:
		"variant-QV_boxplots.pdf"
	conda:
		"matplotlib.yml"
	log:
		"variant-QV_boxplots.log"
	shell:
		"""
		ls {input.qvs} | python3 plot-qv-pav.py {output} &> {log}
		"""
