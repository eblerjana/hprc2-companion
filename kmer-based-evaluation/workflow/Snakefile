from snakemake.utils import validate

configfile: "config/config.yaml"
validate(config, "config.schema.yaml")


include: "rules/validate-inputs.smk"
include: "rules/parse-inputs.smk"
include: "rules/create-consensus-haplotypes.smk"
include: "rules/extract-consensus-fasta.smk"
include: "rules/phase-genotypes.smk"
include: "rules/evaluate-mercury.smk"

def consensus_files(wildcards):
	result = []
	for callset in SAMPLES:
		for sample in SAMPLES[callset]:
			result.extend(expand("{results}/evaluation/{callset}/{sample}_{haplotype}/{sample}_{haplotype}_consensus.fa.gz", results = OUTNAME, callset = callset, sample = sample, haplotype = ["hap1", "hap2"]))
	return result


def sample_specific_results(wildcards):
	result = []
	for callset in SAMPLES:
		reads_present = False
		for sample in SAMPLES[callset]:
			result.extend(expand("{results}/evaluation/qvs-kmers/{callset}_{sample}_{haplotype}.completeness.stats", results = OUTNAME, callset = callset, sample = sample, haplotype = ["hap1", "hap2"]))
			result.extend(expand("{results}/evaluation/qvs-kmers/{callset}_{sample}_{haplotype}.qv", results = OUTNAME, callset = callset, sample = sample, haplotype = ["hap1", "hap2"]))
			result.extend(expand("{results}/evaluation/qvs-kmers/{callset}-qvs-stats.tsv", results = OUTNAME, callset = callset))
			result.extend(expand("{results}/evaluation/qvs-kmers/{callset}-completeness-stats.tsv", results = OUTNAME, callset = callset))
	return result

rule all:
	input:
		consensus_files,
		sample_specific_results
